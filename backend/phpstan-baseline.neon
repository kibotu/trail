		-
			message: '#^Offset ''image/avif''\|''image/gif''\|''image/jpeg''\|''image/png''\|''image/svg\+xml''\|''image/webp'' on array\{''image/jpeg''\: ''jpg'', ''image/png''\: ''png'', ''image/gif''\: ''gif'', ''image/webp''\: ''webp'', ''image/avif''\: ''avif'', ''image/svg\+xml''\: ''svg''\} on left side of \?\? always exists and is not nullable\.$#'
