# ============================================
# Trail Backend - Public Directory Security
# ============================================

# ============================================
# 1. HTTPS Enforcement (Production)
# ============================================
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Force HTTPS in production
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP_HOST} !^localhost [NC]
    RewriteCond %{HTTP_HOST} !^127\.0\.0\.1 [NC]
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# ============================================
# 2. Security Headers
# ============================================
<IfModule mod_headers.c>
    # HSTS - enforce HTTPS for 1 year
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    
    # Prevent clickjacking attacks
    Header always set X-Frame-Options "SAMEORIGIN"
    
    # Prevent MIME type sniffing
    Header always set X-Content-Type-Options "nosniff"
    
    # Referrer policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Content Security Policy (adjust as needed)
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'self';"
    
    # Remove server signature
    Header always unset X-Powered-By
    Header always unset Server
    
    # Permissions Policy (formerly Feature Policy)
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()"

    # Prevent cross-origin information leaks
    Header always set Cross-Origin-Opener-Policy "same-origin"
    Header always set Cross-Origin-Resource-Policy "same-origin"

    # Allow embedding for /@username/embed: unset restrictive headers so PHP can set permissive ones.
    # After mod_rewrite internally redirects to index.php, env vars get prefixed with REDIRECT_,
    # so we must match on REDIRECT_EMBED_REQUEST in the header directives.
    Header always unset X-Frame-Options env=REDIRECT_EMBED_REQUEST
    Header always unset Content-Security-Policy env=REDIRECT_EMBED_REQUEST
    Header always unset Permissions-Policy env=REDIRECT_EMBED_REQUEST
    Header always unset Cross-Origin-Opener-Policy env=REDIRECT_EMBED_REQUEST
    Header always unset Cross-Origin-Resource-Policy env=REDIRECT_EMBED_REQUEST
</IfModule>

# ============================================
# 3. Disable Directory Listing
# ============================================
Options -Indexes

# ============================================
# 4. Disable Server Signature
# ============================================
ServerSignature Off

# ============================================
# 5. Protect Sensitive Files
# ============================================
<FilesMatch "^\.">
    # Apache 2.4+
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    # Apache 2.2
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Protect specific files
<FilesMatch "(composer\.(json|lock)|package(-lock)?\.json|\.env|\.git.*|\.htaccess|\.htpasswd|config\.yml|secrets\.yml)$">
    # Apache 2.4+
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    # Apache 2.2
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# ============================================
# 6. Prevent Access to Backup Files
# ============================================
<FilesMatch "\.(bak|backup|old|orig|save|swp|tmp|~)$">
    # Apache 2.4+
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    # Apache 2.2
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# ============================================
# 7. Prevent Access to Log Files
# ============================================
<FilesMatch "\.(log|sql|sqlite)$">
    # Apache 2.4+
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    # Apache 2.2
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# ============================================
# 8. Block Bad Bots & Scanners
# ============================================
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Block bad user agents (excluding empty user agents to avoid blocking legitimate traffic)
    # Uncomment the following lines if you want stricter bot blocking:
    # RewriteCond %{HTTP_USER_AGENT} (libwww-perl|wget|python|nikto|scan|winhttp|clshttp|loader) [NC,OR]
    # RewriteCond %{HTTP_USER_AGENT} (;|<|>|'|"|\)|\(|%0A|%0D|%27|%3C|%3E|%00) [NC]
    # RewriteRule ^(.*)$ - [F,L]
    
    # Block suspicious query strings
    RewriteCond %{QUERY_STRING} [a-zA-Z0-9_]=http:// [OR]
    RewriteCond %{QUERY_STRING} [a-zA-Z0-9_]=(\.\.//?)+ [OR]
    RewriteCond %{QUERY_STRING} [a-zA-Z0-9_]=/([a-z0-9_.]//?)+ [NC,OR]
    RewriteCond %{QUERY_STRING} \=PHP[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12} [NC,OR]
    RewriteCond %{QUERY_STRING} (\.\./|\.\.) [OR]
    RewriteCond %{QUERY_STRING} ftp\: [NC,OR]
    RewriteCond %{QUERY_STRING} http\: [NC,OR]
    RewriteCond %{QUERY_STRING} https\: [NC,OR]
    RewriteCond %{QUERY_STRING} \=\|w\| [NC,OR]
    RewriteCond %{QUERY_STRING} ^(.*)/self/(.*)$ [NC,OR]
    RewriteCond %{QUERY_STRING} ^(.*)cPath=http://(.*)$ [NC,OR]
    RewriteCond %{QUERY_STRING} (\<|%3C).*script.*(\>|%3E) [NC,OR]
    RewriteCond %{QUERY_STRING} (<|%3C)([^s]*s)+cript.*(>|%3E) [NC,OR]
    RewriteCond %{QUERY_STRING} (\<|%3C).*iframe.*(\>|%3E) [NC,OR]
    RewriteCond %{QUERY_STRING} (<|%3C)([^i]*i)+frame.*(>|%3E) [NC,OR]
    RewriteCond %{QUERY_STRING} base64_encode.*\(.*\) [NC,OR]
    RewriteCond %{QUERY_STRING} base64_(en|de)code[^(]*\([^)]*\) [NC,OR]
    RewriteCond %{QUERY_STRING} GLOBALS(=|\[|\%[0-9A-Z]{0,2}) [OR]
    RewriteCond %{QUERY_STRING} _REQUEST(=|\[|\%[0-9A-Z]{0,2}) [OR]
    RewriteCond %{QUERY_STRING} (NULL|OUTFILE|LOAD_FILE) [OR]
    RewriteCond %{QUERY_STRING} (\.{1,}/)+(motd|etc|bin) [NC,OR]
    RewriteCond %{QUERY_STRING} (localhost|loopback|127\.0\.0\.1) [NC,OR]
    RewriteCond %{QUERY_STRING} (<|>|'|"|%0A|%0D|%22|%27|%3C|%3E|%00) [NC,OR]
    RewriteCond %{QUERY_STRING} concat[^\(]*\( [NC,OR]
    RewriteCond %{QUERY_STRING} union([^s]*s)+elect [NC,OR]
    RewriteCond %{QUERY_STRING} union([^a]*a)+ll([^s]*s)+elect [NC,OR]
    RewriteCond %{QUERY_STRING} (;|<|>|'|"|\)|%0A|%0D|%22|%27|%3C|%3E|%00).*(/\*|union|select|insert|drop|delete|update|cast|create|char|convert|alter|declare|order|script|set|md5|benchmark|encode) [NC]
    RewriteRule ^(.*)$ - [F,L]
</IfModule>

# ============================================
# 9. Limit Request Methods
# ============================================
<LimitExcept GET POST PUT DELETE PATCH OPTIONS>
    # Apache 2.4+
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    # Apache 2.2
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</LimitExcept>

# ============================================
# 10. PHP Security Settings
# ============================================
<IfModule mod_php.c>
    # Disable dangerous PHP functions
    php_flag display_errors Off
    php_flag log_errors On
    php_flag expose_php Off
    php_flag register_globals Off
    php_flag magic_quotes_gpc Off
    php_flag allow_url_fopen Off
    php_flag allow_url_include Off

    # OPcache tuning (CGI/FastCGI equivalent is in .user.ini)
    php_value opcache.enable 1
    php_value opcache.memory_consumption 128
    php_value opcache.interned_strings_buffer 16
    php_value opcache.max_accelerated_files 10000
    php_value opcache.validate_timestamps 0
    php_value opcache.revalidate_freq 0
    php_value opcache.save_comments 1
</IfModule>

# ============================================
# 11. Favicon Redirect
# ============================================
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Redirect /favicon.ico to /assets/favicon.ico
    RewriteRule ^favicon\.ico$ /assets/favicon.ico [L]
</IfModule>

# ============================================
# 12. Front Controller (URL Rewriting)
# ============================================
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Handle Authorization header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
    
    # Tag embed requests so mod_headers can unset restrictive framing headers
    RewriteRule ^@[^/]+/embed$ - [E=EMBED_REQUEST:1]

    # Redirect to front controller
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [QSA,L]
</IfModule>

# ============================================
# 13. MIME Type Security
# ============================================
<IfModule mod_mime.c>
    # Force download for potentially dangerous files
    AddType application/octet-stream .exe .dll .bat .cmd .sh
    
    # Set correct MIME types
    AddType application/javascript .js
    AddType text/css .css
    AddType image/svg+xml .svg
    AddType image/webp .webp
    AddType image/avif .avif
</IfModule>

# ============================================
# 14. Compression (Performance)
# ============================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE \
        text/html \
        text/plain \
        text/xml \
        text/css \
        text/javascript \
        text/x-component \
        text/cache-manifest \
        text/vcard \
        text/vtt \
        text/x-cross-domain-policy \
        application/javascript \
        application/x-javascript \
        application/json \
        application/ld+json \
        application/manifest+json \
        application/schema+json \
        application/geo+json \
        application/rss+xml \
        application/atom+xml \
        application/xml \
        application/xhtml+xml \
        application/vnd.ms-fontobject \
        application/x-font-ttf \
        application/x-font-opentype \
        application/x-font-truetype \
        font/ttf \
        font/otf \
        font/opentype \
        font/eot \
        image/svg+xml \
        image/x-icon \
        image/vnd.microsoft.icon

    # Don't compress already-compressed formats
    SetEnvIfNoCase Request_URI \.(?:gif|jpe?g|png|webp|avif|woff2?|mp4|webm|ogg|zip|gz|br|bz2|rar|7z)$ no-gzip

    # Vary header scoped to compressible content only
    <IfModule mod_headers.c>
        <FilesMatch "\.(html|css|js|json|xml|svg|txt|ico|ttf|otf|eot)$">
            Header append Vary Accept-Encoding
        </FilesMatch>
    </IfModule>
</IfModule>

# ============================================
# 15. Browser Caching (Performance)
# ============================================
<IfModule mod_expires.c>
    ExpiresActive On

    # Fallback: any component not matched below gets 1 month
    ExpiresDefault "access plus 1 month"

    # HTML: never cache (dynamic content)
    ExpiresByType text/html "access plus 0 seconds"

    # Data interchange
    ExpiresByType application/json "access plus 0 seconds"
    ExpiresByType application/ld+json "access plus 0 seconds"
    ExpiresByType application/xml "access plus 0 seconds"
    ExpiresByType text/xml "access plus 0 seconds"

    # Feeds
    ExpiresByType application/rss+xml "access plus 1 hour"
    ExpiresByType application/atom+xml "access plus 1 hour"

    # Favicon / icons
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType image/vnd.microsoft.icon "access plus 1 year"

    # Images
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/avif "access plus 1 year"
    ExpiresByType image/bmp "access plus 1 year"
    ExpiresByType image/tiff "access plus 1 year"

    # Video / Audio
    ExpiresByType video/mp4 "access plus 1 year"
    ExpiresByType video/webm "access plus 1 year"
    ExpiresByType video/ogg "access plus 1 year"
    ExpiresByType audio/ogg "access plus 1 year"
    ExpiresByType audio/mpeg "access plus 1 year"

    # Fonts
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/eot "access plus 1 year"
    ExpiresByType application/vnd.ms-fontobject "access plus 1 year"
    ExpiresByType application/x-font-ttf "access plus 1 year"
    ExpiresByType application/x-font-opentype "access plus 1 year"
    ExpiresByType application/x-font-woff "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"

    # CSS / JavaScript
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType application/x-javascript "access plus 1 year"

    # Manifest / Service Worker
    ExpiresByType application/manifest+json "access plus 1 year"
    ExpiresByType text/cache-manifest "access plus 0 seconds"

    # Documents
    ExpiresByType application/pdf "access plus 1 month"
</IfModule>

# ============================================
# 16. Cache-Control Headers
# ============================================
<IfModule mod_headers.c>
    FileETag MTime Size

    # Immutable static assets (images, fonts, media)
    <FilesMatch "\.(ico|jpg|jpeg|png|gif|webp|avif|svg|bmp|tiff|mp4|webm|ogg|woff|woff2|ttf|otf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # CSS/JS with cache-busting via query string or hashed filenames
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # HTML: no cache
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
    </FilesMatch>

    # User-uploaded images: shorter cache with revalidation
    <FilesMatch "^uploads-">
        Header set Cache-Control "public, max-age=604800, stale-while-revalidate=86400"
    </FilesMatch>
</IfModule>
